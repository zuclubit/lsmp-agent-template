<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <isExposed>true</isExposed>
    <description>Real-time migration dashboard showing KPIs, progress bars, object breakdown, and error log for the LSMP migration platform.</description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__Tab</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage">
            <property name="autoRefreshInterval" type="Integer" default="30" label="Auto-refresh interval (seconds)" min="10" max="300"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
