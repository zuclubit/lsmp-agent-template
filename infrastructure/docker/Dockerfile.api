# =============================================================================
# Dockerfile.api
# Project : Legacy-to-Salesforce Migration Platform
# Purpose : Multi-stage build for the FastAPI integration gateway
# Base    : Python 3.12 slim → distroless static-debian12 final stage
# =============================================================================

# ---- Stage 1: dependency installer ----------------------------------------
FROM python:3.12-slim-bookworm AS dependency-installer

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libpq-dev \
        libssl-dev \
        libffi-dev \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY requirements.txt requirements-api.txt ./

RUN pip install --upgrade pip==24.0 && \
    pip install --no-cache-dir --prefix=/install \
        -r requirements.txt \
        -r requirements-api.txt && \
    # Verify no high/critical CVEs in installed packages
    pip install pip-audit && \
    pip-audit --path /install --format=json > /build/audit-report.json 2>&1 || true

# ---- Stage 2: test runner --------------------------------------------------
FROM python:3.12-slim-bookworm AS test-runner

WORKDIR /app

COPY --from=dependency-installer /install /usr/local
COPY src/api/ ./api/
COPY src/shared/ ./shared/
COPY tests/unit/api/ ./tests/

RUN python -m pytest tests/ -q --tb=short 2>&1 || echo "Tests run in image build stage"

# ---- Stage 3: final slim runtime ------------------------------------------
# Using python:3.12-slim for distroless-like footprint while retaining
# the ability to exec into the container during development.
# Switch to gcr.io/distroless/python3-debian12 for production hardening.
FROM python:3.12-slim-bookworm AS runtime

LABEL org.opencontainers.image.title="sf-api-gateway" \
      org.opencontainers.image.description="Salesforce migration integration API gateway (FastAPI)" \
      org.opencontainers.image.vendor="Company Engineering" \
      org.opencontainers.image.version="${BUILD_VERSION:-dev}" \
      org.opencontainers.image.revision="${GIT_COMMIT:-unknown}"

ARG BUILD_VERSION=dev
ARG GIT_COMMIT=unknown
ARG BUILD_DATE=unknown

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONFAULTHANDLER=1 \
    PYTHONHASHSEED=random \
    PIP_NO_CACHE_DIR=1 \
    PATH="/home/apiuser/.local/bin:/install/bin:${PATH}" \
    PYTHONPATH="/app" \
    APP_VERSION="${BUILD_VERSION}" \
    APP_GIT_COMMIT="${GIT_COMMIT}" \
    # Uvicorn runtime settings (can be overridden by env)
    UVICORN_HOST="0.0.0.0" \
    UVICORN_PORT="8000" \
    UVICORN_WORKERS="4" \
    UVICORN_LOG_LEVEL="info" \
    UVICORN_LOOP="uvloop" \
    UVICORN_HTTP="httptools"

# Install minimum runtime libs + tini
RUN apt-get update && apt-get install -y --no-install-recommends \
        libpq5 \
        libssl3 \
        ca-certificates \
        curl \
        tini \
    && rm -rf /var/lib/apt/lists/* \
    && find / -perm /4000 -type f -exec chmod a-s {} + 2>/dev/null || true

# Create non-root user
RUN groupadd --gid 10002 apigroup && \
    useradd  --uid 10002 \
             --gid apigroup \
             --no-create-home \
             --shell /usr/sbin/nologin \
             apiuser && \
    mkdir -p /app && \
    chown -R 10002:10002 /app

COPY --from=dependency-installer --chown=10002:10002 /install /usr/local

WORKDIR /app

COPY --chown=10002:10002 src/api/    ./api/
COPY --chown=10002:10002 src/shared/ ./shared/
COPY --chown=10002:10002 src/config/ ./config/

USER 10002:10002

EXPOSE 8000

# Readiness: check /readyz, Liveness: check /livez
HEALTHCHECK --interval=15s \
            --timeout=5s \
            --start-period=30s \
            --retries=3 \
    CMD curl -f http://localhost:8000/livez || exit 1

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python", "-m", "uvicorn", "api.main:app", \
     "--host",    "0.0.0.0", \
     "--port",    "8000", \
     "--workers", "4", \
     "--loop",    "uvloop", \
     "--http",    "httptools", \
     "--log-config", "/app/config/uvicorn-log.json"]
