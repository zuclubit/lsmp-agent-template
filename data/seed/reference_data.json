  "skip_conditions": {
    "accounts": [
      {
        "field": "acct_status",
        "value": "S",
        "action": "skip",
        "reason": "Suspended accounts should not be migrated to Salesforce"
      },
      {
        "field": "acct_name",
        "value": null,
        "action": "error",
        "reason": "Account name is required"
      },
      {
        "field": "acct_name",
        "value": "",
        "action": "error",
        "reason": "Account name cannot be blank"
      }
    ],
    "contacts": [
      {
        "field": "last_name",
        "value": null,
        "action": "error",
        "reason": "Contact last_name is required by Salesforce"
      },
      {
        "field": "contact_status",
        "value": "I",
        "action": "migrate_with_opt_out",
        "reason": "Inactive contacts migrate with HasOptedOutOfEmail = true"
      }
    ]
  },
  "sf_object_limits": {
    "Account": {
      "Name": { "type": "string", "max_length": 255 },
      "Description": { "type": "textarea", "max_length": 32000 },
