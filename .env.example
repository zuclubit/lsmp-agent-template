# =============================================================================
# .env.example
# Legacy → Salesforce Migration Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Salesforce Connection
# ---------------------------------------------------------------------------
# Salesforce org login URL.
# Use https://test.salesforce.com for sandboxes.
SF_INSTANCE_URL=https://login.salesforce.com

# Salesforce username (email) of the integration service account.
SF_USERNAME=migration.user@yourcompany.com

# Salesforce password for the service account.
SF_PASSWORD=YourSalesforcePassword123!

# Salesforce security token appended to password for non-trusted-IP logins.
# Get it via: Setup → My Personal Information → Reset My Security Token.
# Leave blank if your IP is whitelisted in Salesforce.
SF_SECURITY_TOKEN=abcXYZ12345securitytoken

# Salesforce API version to use (minimum 55.0 recommended for Bulk API 2.0).
SF_API_VERSION=59.0

# Salesforce Org ID (18-character). Found in Setup → Company Information.
SF_ORG_ID=00D000000000001AAA

# Salesforce User ID to assign as record owner for migrated records.
# Leave blank to use the integration user's default.
SF_MIGRATION_OWNER_ID=

# ---------------------------------------------------------------------------
# Legacy Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Async connection string using asyncpg driver.
# Format: postgresql+asyncpg://user:password@host:port/database
LEGACY_DB_URL=postgresql+asyncpg://erp_readonly:password@localhost:5432/legacy_erp

# Connection pool settings
LEGACY_DB_POOL_SIZE=10
LEGACY_DB_MAX_OVERFLOW=20
LEGACY_DB_POOL_TIMEOUT=30

# ---------------------------------------------------------------------------
# Migration Tracking Database (separate from legacy DB; stores job state)
# ---------------------------------------------------------------------------
MIGRATION_DB_URL=postgresql+asyncpg://migration_user:password@localhost:5432/migration_tracking

# ---------------------------------------------------------------------------
# Migration Configuration
# ---------------------------------------------------------------------------
# Source system identifier (used in job metadata).
LEGACY_SOURCE_SYSTEM=ERP_v2

# Default batch size for Salesforce API calls (1–2000; 200 is recommended).
MIGRATION_BATCH_SIZE=200

# Percentage of failed records that triggers an automatic job abort.
MIGRATION_ERROR_THRESHOLD=5.0

# Set to true to simulate migration without writing to Salesforce.
MIGRATION_DRY_RUN=false

# Maximum retries for a single record before marking it permanently failed.
MIGRATION_MAX_RETRIES=3

# Comma-separated record types to migrate.
MIGRATION_RECORD_TYPES=Account,Contact

# ---------------------------------------------------------------------------
# Event Bus / Message Queue
# ---------------------------------------------------------------------------
# Set to "kafka" or "service_bus" or "none".
EVENT_BUS_TYPE=none

# Apache Kafka (if EVENT_BUS_TYPE=kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=migration-service
KAFKA_TOPIC_PREFIX=migration

# Azure Service Bus (if EVENT_BUS_TYPE=service_bus)
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_TOPIC_NAME=migration-events
AZURE_SERVICE_BUS_SUBSCRIPTION_NAME=migration-service

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
# Comma-separated email addresses to notify on completion/failure.
NOTIFICATION_EMAILS=migration-team@yourcompany.com,cto@yourcompany.com

# SMTP configuration for email notifications.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM_ADDRESS=migration-agent@yourcompany.com
SMTP_FROM_NAME=Migration Agent

# Slack webhook URL for status notifications (leave blank to disable).
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/xxxxxxxxxxxx

# PagerDuty integration key (leave blank to disable).
PAGERDUTY_INTEGRATION_KEY=

# ---------------------------------------------------------------------------
# Cloud Storage for Backups and Reports
# ---------------------------------------------------------------------------
# AWS S3 (leave blank to disable S3 upload)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BACKUP_S3_BUCKET=s3://your-migration-backups/legacy-erp

# Azure Blob Storage (leave blank to disable)
BACKUP_AZURE_CONNECTION_STRING=
BACKUP_AZURE_CONTAINER=migration-backups

# ---------------------------------------------------------------------------
# API Server (FastAPI)
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
API_ALLOWED_HOSTS=localhost,127.0.0.1
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
API_LOG_LEVEL=INFO
API_RELOAD=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log output directory (created automatically if not present)
LOG_DIR=./logs

# Log file rotation: max size in MB and backup count
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=10

# Set to "json" for structured logging (recommended in production).
LOG_FORMAT=text

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Encryption key for sensitive field values in the migration tracking DB.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FIELD_ENCRYPTION_KEY=change-me-generate-with-secrets-module

# JWT signing secret for API authentication.
JWT_SECRET_KEY=change-me-generate-with-secrets-module
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
# Enable debug endpoints (/debug/*, /metrics) — NEVER enable in production.
ENABLE_DEBUG_ENDPOINTS=false

# Enable migration rollback capability.
ENABLE_ROLLBACK=true

# Validate SSL certificates when connecting to Salesforce (always true in prod).
SF_VERIFY_SSL=true

# ---------------------------------------------------------------------------
# Monitoring / Observability
# ---------------------------------------------------------------------------
# Prometheus metrics endpoint
PROMETHEUS_METRICS_ENABLED=false
PROMETHEUS_METRICS_PORT=9090

# OpenTelemetry trace export endpoint (e.g. Jaeger, Zipkin, Datadog)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=migration-agent
