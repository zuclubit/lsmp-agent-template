{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "graph", "name": "Graph", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Legacy to Salesforce Migration Progress Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Migration Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "green", "value": 80}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "100 * sum(migration_records_processed_total{environment=~\"$environment\", status=\"success\"}) / sum(migration_records_processed_total{environment=~\"$environment\"})",
          "legendFormat": "Overall Progress",
          "refId": "A"
        }
      ],
      "title": "Overall Migration Progress",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 3, "w": 4, "x": 6, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(migration_jobs_active{environment=~\"$environment\"})",
          "legendFormat": "Active Jobs",
          "refId": "A"
        }
      ],
      "title": "Active Jobs",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 100}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 3, "w": 4, "x": 10, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(migration_dead_letter_queue_size{environment=~\"$environment\"})",
          "legendFormat": "DLQ Size",
          "refId": "A"
        }
      ],
      "title": "Dead Letter Queue",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5000},
              {"color": "red", "value": 1000}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 3, "w": 4, "x": 14, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "salesforce_api_rate_limit_remaining{environment=~\"$environment\"}",
          "legendFormat": "SF API Remaining",
          "refId": "A"
        }
      ],
      "title": "Salesforce API Remaining",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "lineWidth": 2
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
      "id": 10,
      "options": {
        "legend": {"calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (source_object) (rate(migration_records_processed_total{environment=~\"$environment\", status=\"success\"}[5m]) * 60)",
          "legendFormat": "{{source_object}} - Success",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (source_object) (rate(migration_records_processed_total{environment=~\"$environment\", status=\"failed\"}[5m]) * 60)",
          "legendFormat": "{{source_object}} - Failed",
          "refId": "B"
        }
      ],
      "title": "Records Processed per Minute",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 7},
      "id": 11,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (source_object) (rate(migration_errors_total{environment=~\"$environment\"}[5m])) / sum by (source_object) (rate(migration_records_processed_total{environment=~\"$environment\"}[5m]))",
          "legendFormat": "{{source_object}}",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Object",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15},
      "id": 101,
      "title": "Phase Progress",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "green", "value": 90}
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 20,
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "100 * sum by (source_object) (migration_records_processed_total{environment=~\"$environment\", phase=\"loading\", status=\"success\"}) / sum by (source_object) (migration_records_processed_total{environment=~\"$environment\", phase=\"extraction\"})",
          "legendFormat": "{{source_object}}",
          "refId": "A"
        }
      ],
      "title": "Migration Completion % by Object",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "id": 102,
      "title": "Salesforce API",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "id": 30,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum by (le, object_name) (rate(salesforce_api_duration_seconds_bucket{environment=~\"$environment\"}[5m])))",
          "legendFormat": "{{object_name}} p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum by (le, object_name) (rate(salesforce_api_duration_seconds_bucket{environment=~\"$environment\"}[5m])))",
          "legendFormat": "{{object_name}} p95",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum by (le, object_name) (rate(salesforce_api_duration_seconds_bucket{environment=~\"$environment\"}[5m])))",
          "legendFormat": "{{object_name}} p99",
          "refId": "C"
        }
      ],
      "title": "Salesforce API Latency (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "id": 31,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (object_name) (rate(salesforce_api_requests_total{environment=~\"$environment\", status_code=~\"2..\"}[5m]))",
          "legendFormat": "{{object_name}} 2xx",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (object_name) (rate(salesforce_api_requests_total{environment=~\"$environment\", status_code=~\"[45]..\"}[5m]))",
          "legendFormat": "{{object_name}} errors",
          "refId": "B"
        }
      ],
      "title": "Salesforce API Request Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33},
      "id": 103,
      "title": "SLA Compliance",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 95},
              {"color": "green", "value": 99}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 34},
      "id": 40,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "100 * (1 - (sum(migration_sla_breaches_total{environment=~\"$environment\"}) / sum(migration_jobs_total{environment=~\"$environment\", status=\"completed\"})))",
          "legendFormat": "SLA Compliance Rate",
          "refId": "A"
        }
      ],
      "title": "SLA Compliance Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "color-background"
          }
        }
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 40},
      "id": 50,
      "options": {
        "footer": {"show": false},
        "showHeader": true,
        "sortBy": [{"displayName": "Error Rate", "desc": true}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (source_object) (migration_records_processed_total{environment=~\"$environment\"})",
          "legendFormat": "{{source_object}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Migration Summary by Object",
      "type": "table",
      "transformations": [
        {"id": "organize", "options": {
          "renameByName": {
            "source_object": "Object",
            "Value": "Total Records"
          }
        }}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["migration", "salesforce", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "production", "value": "production"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(migration_jobs_total, environment)",
        "hide": 0,
        "includeAll": false,
        "label": "Environment",
        "multi": false,
        "name": "environment",
        "options": [],
        "query": "label_values(migration_jobs_total, environment)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Migration Progress Dashboard",
  "uid": "migration-progress-v1",
  "version": 1
}
