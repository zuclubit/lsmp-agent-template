<?xml version="1.0" encoding="UTF-8"?>
<!--
    Profile: Migration_Admin
    Description: Full administrative profile for the Legacy-to-Salesforce
                 migration team. Grants all object and field permissions
                 required to execute, monitor, and roll back migrations.
    Author  : Migration Platform Team
    Modified: 2026-03-16
-->
<Profile xmlns="http://soap.sforce.com/2006/04/metadata">
    <custom>true</custom>
    <description>Migration Admin - Full access profile for migration operations team</description>

    <!-- ═══════════════════════════════════════════════════════════════════════
         APPLICATION VISIBILITY
    ══════════════════════════════════════════════════════════════════════════ -->
    <applicationVisibilities>
        <application>standard__Service</application>
        <default>false</default>
        <visible>true</visible>
    </applicationVisibilities>
    <applicationVisibilities>
        <application>standard__Sales</application>
        <default>true</default>
        <visible>true</visible>
    </applicationVisibilities>
    <applicationVisibilities>
        <application>Migration_App</application>
        <default>false</default>
        <visible>true</visible>
    </applicationVisibilities>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CLASS ACCESS
    ══════════════════════════════════════════════════════════════════════════ -->
    <classAccesses>
        <apexClass>AccountService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>MigrationBatchProcessor</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>IntegrationService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AuditLogService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>MigrationDashboardController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AccountTriggerHandler</apexClass>
        <enabled>true</enabled>
    </classAccesses>

