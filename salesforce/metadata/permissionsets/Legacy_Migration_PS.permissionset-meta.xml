<?xml version="1.0" encoding="UTF-8"?>
<!--
    Permission Set: Legacy_Migration_PS
    Description   : Grants migration-specific permissions to team members
                    without elevating their base profile. Assignable to any
                    Salesforce-licensed user during the migration project.
    Author        : Migration Platform Team
    Modified      : 2026-03-16
-->
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Legacy to Salesforce Migration — operational permission set for migration team members</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Legacy Migration Operator</label>
    <license>Salesforce</license>

    <!-- ═══════════════════════════════════════════════════════════════════════
         APEX CLASS ACCESS
    ══════════════════════════════════════════════════════════════════════════ -->
    <classAccesses>
        <apexClass>AccountService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>MigrationBatchProcessor</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>IntegrationService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AuditLogService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>MigrationDashboardController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CUSTOM PERMISSIONS
    ══════════════════════════════════════════════════════════════════════════ -->
    <customPermissions>
        <enabled>true</enabled>
        <name>Run_Migration_Batch</name>
    </customPermissions>
    <customPermissions>
        <enabled>true</enabled>
        <name>View_Migration_Audit_Logs</name>
    </customPermissions>
    <customPermissions>
        <enabled>false</enabled>
        <name>Migration_Bypass_Lock</name>
    </customPermissions>

    <!-- ═══════════════════════════════════════════════════════════════════════
         FIELD PERMISSIONS — ACCOUNT (migration fields only)
    ══════════════════════════════════════════════════════════════════════════ -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Legacy_ID__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Migration_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Account.Migration_Batch__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Account.Migration_Completed_Date__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Account.Migration_Failed_Date__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Active__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Account.Address_Verified__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- ═══════════════════════════════════════════════════════════════════════
         FIELD PERMISSIONS — MIGRATIONLOG__C
    ══════════════════════════════════════════════════════════════════════════ -->
    <fieldPermissions>
        <editable>false</editable>
        <field>MigrationLog__c.Batch_Job_Id__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>MigrationLog__c.Run_Id__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>MigrationLog__c.Object_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>MigrationLog__c.Total_Processed__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>MigrationLog__c.Total_Success__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>MigrationLog__c.Total_Failed__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>MigrationLog__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>MigrationLog__c.Summary__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>MigrationLog__c.Dry_Run__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- ═══════════════════════════════════════════════════════════════════════
         FIELD PERMISSIONS — AUDIT_LOG__C
    ══════════════════════════════════════════════════════════════════════════ -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Audit_Log__c.Log_Level__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Audit_Log__c.Source__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Audit_Log__c.Action__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Audit_Log__c.Message__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Audit_Log__c.Related_Record_Id__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Audit_Log__c.User_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Audit_Log__c.Timestamp__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- ═══════════════════════════════════════════════════════════════════════
         OBJECT PERMISSIONS
    ══════════════════════════════════════════════════════════════════════════ -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Contact</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>MigrationLog__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Audit_Log__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- ═══════════════════════════════════════════════════════════════════════
         TAB SETTINGS
    ══════════════════════════════════════════════════════════════════════════ -->
    <tabSettings>
        <tab>MigrationLog__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Audit_Log__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- ═══════════════════════════════════════════════════════════════════════
         PAGE ACCESS
    ══════════════════════════════════════════════════════════════════════════ -->
    <pageAccesses>
        <apexPage>MigrationDashboardPage</apexPage>
        <enabled>true</enabled>
    </pageAccesses>

</PermissionSet>
