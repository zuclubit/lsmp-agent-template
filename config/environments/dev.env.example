# ============================================================
# Development Environment Configuration
# Legacy to Salesforce Migration Platform
# ============================================================
# DO NOT commit real secrets. This file shows required variables
# with placeholder values only.
# Copy to .env and fill in real values for local development.
# ============================================================

# ---- Application ----
ENVIRONMENT=development
SERVICE_NAME=migration-platform
SERVICE_VERSION=local-dev
LOG_LEVEL=DEBUG
LOG_FORMAT=text
DEBUG=true

# ---- API Server ----
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true
API_TIMEOUT_SECONDS=30
API_MAX_REQUEST_SIZE_MB=50
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ---- Database (Legacy Source) ----
LEGACY_DB_HOST=localhost
LEGACY_DB_PORT=1433
LEGACY_DB_NAME=legacy_crm_dev
LEGACY_DB_USERNAME=migration_dev_user
LEGACY_DB_PASSWORD=CHANGE_ME_DEV_DB_PASSWORD
LEGACY_DB_SSL_MODE=disable
LEGACY_DB_POOL_MIN=2
LEGACY_DB_POOL_MAX=10
LEGACY_DB_POOL_TIMEOUT_SECONDS=30
LEGACY_DB_CONNECTION_TIMEOUT_SECONDS=10

# ---- PostgreSQL (Migration State DB) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=migration_state_dev
POSTGRES_USER=migration_app
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_SSL_MODE=disable
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20

# ---- Salesforce ----
SALESFORCE_INSTANCE_URL=https://dev-sandbox.sandbox.my.salesforce.com
SALESFORCE_CLIENT_ID=CHANGE_ME_SF_CLIENT_ID
SALESFORCE_CLIENT_SECRET=CHANGE_ME_SF_CLIENT_SECRET
SALESFORCE_USERNAME=migration-user@company.dev
SALESFORCE_PASSWORD=CHANGE_ME_SF_PASSWORD
SALESFORCE_SECURITY_TOKEN=CHANGE_ME_SF_SECURITY_TOKEN
SALESFORCE_API_VERSION=59.0
SALESFORCE_BULK_API_VERSION=2
SALESFORCE_MAX_CONNECTIONS=5
SALESFORCE_TIMEOUT_SECONDS=60
SALESFORCE_RETRY_ATTEMPTS=3
SALESFORCE_BULK_BATCH_SIZE=10000

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_GROUP_ID=migration-consumer-dev
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_MAX_POLL_RECORDS=500
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_TOPICS_MIGRATION_EVENTS=migration-events-dev
KAFKA_TOPICS_ERROR_EVENTS=migration-errors-dev
KAFKA_TOPICS_AUDIT_EVENTS=migration-audit-dev

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_ENABLED=false
REDIS_MAX_CONNECTIONS=50
REDIS_TIMEOUT_SECONDS=5
REDIS_CACHE_DEFAULT_TTL_SECONDS=300

# ---- HashiCorp Vault ----
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=CHANGE_ME_VAULT_ROOT_TOKEN_DEV_ONLY
VAULT_MOUNT_PATH=migration
VAULT_NAMESPACE=
VAULT_TLS_VERIFY=false
VAULT_K8S_ROLE=
VAULT_CACHE_TTL_SECONDS=300

# ---- Azure Key Vault (optional fallback) ----
AZURE_TENANT_ID=CHANGE_ME_AZURE_TENANT_ID
AZURE_CLIENT_ID=CHANGE_ME_AZURE_CLIENT_ID
AZURE_CLIENT_SECRET=CHANGE_ME_AZURE_CLIENT_SECRET
AZURE_KEY_VAULT_URL=https://migration-dev-kv.vault.azure.net
AZURE_USE_MANAGED_IDENTITY=false

# ---- Security / Auth ----
JWT_PUBLIC_KEY_PATH=./dev-keys/jwt-public.pem
JWT_PRIVATE_KEY_PATH=./dev-keys/jwt-private.pem
JWT_ALGORITHM=RS256
JWT_EXPIRY_MINUTES=480
AUTH_MFA_REQUIRED=false
AUTH_SESSION_TIMEOUT_MINUTES=480

# ---- Encryption ----
DEV_ENCRYPTION_SEED=dev-local-encryption-seed-not-for-production
# In dev, master key is derived from DEV_ENCRYPTION_SEED
# In staging/prod, set ENCRYPTION_MASTER_KEY_B64 from Vault

# ---- Audit Logging ----
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE_PATH=./logs/audit.jsonl
AUDIT_LOG_ELASTICSEARCH_ENABLED=false
AUDIT_LOG_ELASTICSEARCH_URL=
AUDIT_CHAIN_KEY_HEX=

# ---- Migration Settings ----
MIGRATION_BATCH_SIZE=500
MIGRATION_MAX_PARALLEL_JOBS=2
MIGRATION_RETRY_ATTEMPTS=3
MIGRATION_RETRY_DELAY_SECONDS=5
MIGRATION_RETRY_MAX_DELAY_SECONDS=60
MIGRATION_TIMEOUT_HOURS=24
MIGRATION_CHECKPOINT_INTERVAL_RECORDS=1000
MIGRATION_DRY_RUN=false
MIGRATION_ENABLE_ROLLBACK=true

# ---- Feature Flags ----
FEATURE_BULK_API_V2=true
FEATURE_PARALLEL_TRANSFORMATION=false
FEATURE_AI_VALIDATION=false
FEATURE_INCREMENTAL_MIGRATION=false
FEATURE_FIELD_LEVEL_ENCRYPTION=false
FEATURE_AUDIT_CHAIN=false

# ---- Monitoring / Observability ----
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
OTEL_TRACING_ENABLED=false
OTEL_EXPORTER_TYPE=console
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLE_RATE=1.0
LOG_DEBUG_SAMPLE_RATE=1.0

# ---- Notifications ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME/CHANGE_ME/CHANGE_ME
PAGERDUTY_ROUTING_KEY=
ALERT_EMAIL_RECIPIENTS=dev-team@company.com
ALERT_EMAIL_SMTP_HOST=localhost
ALERT_EMAIL_SMTP_PORT=1025

# ---- Storage ----
BLOB_STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./tmp/migration-data
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=migration-artifacts-dev
AWS_S3_BUCKET=
AWS_REGION=us-east-1
