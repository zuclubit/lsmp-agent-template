# ============================================================
# Production Environment Configuration
# Legacy to Salesforce Migration Platform
# ============================================================
# ALL secrets are loaded from HashiCorp Vault via Kubernetes auth.
# No secrets should ever be set as literal values here.
# This file serves as documentation for required env vars.
# Kubernetes secrets/configmaps inject the actual values.
# ============================================================

# ---- Application ----
ENVIRONMENT=production
SERVICE_NAME=migration-platform
SERVICE_VERSION=INJECT_FROM_CI_GIT_SHA
LOG_LEVEL=INFO
LOG_FORMAT=json
DEBUG=false

# ---- API Server ----
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=8
API_RELOAD=false
API_TIMEOUT_SECONDS=120
API_MAX_REQUEST_SIZE_MB=100
CORS_ORIGINS=https://migration.company.com
API_RATE_LIMIT_PER_MINUTE=200
API_RATE_LIMIT_BURST=50

# ---- Database (Legacy Source) ----
LEGACY_DB_HOST=legacy-db-primary.company.internal
LEGACY_DB_PORT=1433
LEGACY_DB_NAME=legacy_crm_production
LEGACY_DB_USERNAME=migration_prod_user
LEGACY_DB_PASSWORD=FROM_VAULT:migration/data/database/legacy-db#password
LEGACY_DB_SSL_MODE=verify-full
LEGACY_DB_SSL_CERT_PATH=/etc/ssl/certs/legacy-db-ca.crt
LEGACY_DB_POOL_MIN=10
LEGACY_DB_POOL_MAX=50
LEGACY_DB_POOL_TIMEOUT_SECONDS=30
LEGACY_DB_CONNECTION_TIMEOUT_SECONDS=15
LEGACY_DB_REPLICA_HOST=legacy-db-replica.company.internal
LEGACY_DB_READ_PREFERENCE=secondary

# ---- PostgreSQL (Migration State DB) ----
POSTGRES_HOST=postgres-primary.migration-system.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_DB=migration_state_production
POSTGRES_USER=migration_app
POSTGRES_PASSWORD=FROM_VAULT:migration/data/database/postgres#password
POSTGRES_SSL_MODE=verify-full
POSTGRES_SSL_CERT_PATH=/etc/ssl/certs/postgres-ca.crt
POSTGRES_POOL_MIN=10
POSTGRES_POOL_MAX=100
POSTGRES_REPLICA_HOST=postgres-replica.migration-system.svc.cluster.local

# ---- Salesforce ----
SALESFORCE_INSTANCE_URL=https://company.my.salesforce.com
SALESFORCE_CLIENT_ID=FROM_VAULT:migration/data/salesforce/credentials#client_id
SALESFORCE_CLIENT_SECRET=FROM_VAULT:migration/data/salesforce/credentials#client_secret
SALESFORCE_USERNAME=migration-user@company.com
SALESFORCE_PASSWORD=FROM_VAULT:migration/data/salesforce/credentials#password
SALESFORCE_SECURITY_TOKEN=FROM_VAULT:migration/data/salesforce/credentials#security_token
SALESFORCE_API_VERSION=59.0
SALESFORCE_BULK_API_VERSION=2
SALESFORCE_MAX_CONNECTIONS=20
SALESFORCE_TIMEOUT_SECONDS=300
SALESFORCE_RETRY_ATTEMPTS=5
SALESFORCE_BULK_BATCH_SIZE=10000
SALESFORCE_RATE_LIMIT_BUFFER=1000
SALESFORCE_CONCURRENT_JOBS_MAX=5

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=kafka-1.migration-system.svc.cluster.local:9092,kafka-2.migration-system.svc.cluster.local:9092,kafka-3.migration-system.svc.cluster.local:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SASL_USERNAME=migration-prod
KAFKA_SASL_PASSWORD=FROM_VAULT:migration/data/kafka#sasl_password
KAFKA_SSL_CA_CERT_PATH=/etc/ssl/certs/kafka-ca.crt
KAFKA_GROUP_ID=migration-consumer-production
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_MAX_POLL_RECORDS=500
KAFKA_SESSION_TIMEOUT_MS=45000
KAFKA_REPLICATION_FACTOR=3
KAFKA_TOPICS_MIGRATION_EVENTS=migration-events
KAFKA_TOPICS_ERROR_EVENTS=migration-errors
KAFKA_TOPICS_AUDIT_EVENTS=migration-audit
KAFKA_TOPICS_DLQ=migration-dlq

# ---- Redis (Cluster Mode) ----
REDIS_CLUSTER_NODES=redis-0.migration-system.svc.cluster.local:6380,redis-1.migration-system.svc.cluster.local:6380,redis-2.migration-system.svc.cluster.local:6380
REDIS_PASSWORD=FROM_VAULT:migration/data/redis#password
REDIS_DB=0
REDIS_TLS_ENABLED=true
REDIS_TLS_CERT_PATH=/etc/ssl/certs/redis-ca.crt
REDIS_MAX_CONNECTIONS=200
REDIS_TIMEOUT_SECONDS=5
REDIS_CACHE_DEFAULT_TTL_SECONDS=300
REDIS_CLUSTER_MODE=true

# ---- HashiCorp Vault ----
VAULT_ADDR=https://vault.migration-system.svc.cluster.local:8200
VAULT_MOUNT_PATH=migration
VAULT_NAMESPACE=migration-production
VAULT_TLS_VERIFY=true
VAULT_CA_CERT_PATH=/etc/ssl/certs/vault-ca.crt
VAULT_K8S_ROLE=migration-api
VAULT_CACHE_TTL_SECONDS=300
# VAULT_TOKEN is NOT set — Kubernetes auth is used exclusively

# ---- Azure Key Vault (disaster recovery fallback) ----
AZURE_TENANT_ID=INJECT_FROM_WORKLOAD_IDENTITY
AZURE_KEY_VAULT_URL=https://migration-prod-kv.vault.azure.net
AZURE_USE_MANAGED_IDENTITY=true
# Client ID provided by Pod Workload Identity annotation

# ---- Security / Auth ----
JWT_PUBLIC_KEY_PATH=/etc/migration/keys/jwt-public.pem
JWT_PRIVATE_KEY_PATH=/etc/migration/keys/jwt-private.pem
JWT_ALGORITHM=RS256
JWT_EXPIRY_MINUTES=60
AUTH_MFA_REQUIRED=true
AUTH_SESSION_TIMEOUT_MINUTES=60
OKTA_DOMAIN=company.okta.com
OKTA_CLIENT_ID=FROM_VAULT:migration/data/api-keys#okta_client_id
OKTA_CLIENT_SECRET=FROM_VAULT:migration/data/api-keys#okta_client_secret

# ---- Encryption ----
ENCRYPTION_MASTER_KEY_B64=FROM_VAULT:migration/data/encryption#master_key_b64
ENCRYPTION_KEY_ID=master-key-prod-v1
ENCRYPTION_KEY_ROTATION_DAYS=90

# ---- Audit Logging ----
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE_PATH=/var/log/migration/audit.jsonl
AUDIT_LOG_ELASTICSEARCH_ENABLED=true
AUDIT_LOG_ELASTICSEARCH_URL=https://elasticsearch.monitoring.svc.cluster.local:9200
AUDIT_LOG_ELASTICSEARCH_INDEX_PREFIX=migration-audit-prod
AUDIT_LOG_ELASTICSEARCH_API_KEY=FROM_VAULT:migration/data/api-keys#elasticsearch_api_key
AUDIT_CHAIN_KEY_HEX=FROM_VAULT:migration/data/encryption#audit_chain_key
AUDIT_LOG_RETENTION_DAYS=2555

# ---- Migration Settings ----
MIGRATION_BATCH_SIZE=5000
MIGRATION_MAX_PARALLEL_JOBS=5
MIGRATION_RETRY_ATTEMPTS=5
MIGRATION_RETRY_DELAY_SECONDS=30
MIGRATION_RETRY_MAX_DELAY_SECONDS=600
MIGRATION_TIMEOUT_HOURS=72
MIGRATION_CHECKPOINT_INTERVAL_RECORDS=10000
MIGRATION_DRY_RUN=false
MIGRATION_ENABLE_ROLLBACK=true
MIGRATION_REQUIRE_APPROVAL=true
MIGRATION_APPROVAL_TIMEOUT_HOURS=4
MIGRATION_MAX_ERROR_RATE_PERCENT=2

# ---- Circuit Breaker ----
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3

# ---- Feature Flags ----
FEATURE_BULK_API_V2=true
FEATURE_PARALLEL_TRANSFORMATION=true
FEATURE_AI_VALIDATION=false
FEATURE_INCREMENTAL_MIGRATION=true
FEATURE_FIELD_LEVEL_ENCRYPTION=true
FEATURE_AUDIT_CHAIN=true

# ---- Monitoring / Observability ----
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
OTEL_TRACING_ENABLED=true
OTEL_EXPORTER_TYPE=otlp_grpc
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo.monitoring.svc.cluster.local:4317
OTEL_SAMPLE_RATE=0.1
OTEL_TENANT_ID=migration-production
LOG_DEBUG_SAMPLE_RATE=0.0

# ---- Notifications ----
SLACK_WEBHOOK_URL=FROM_VAULT:migration/data/api-keys#slack_webhook_prod
PAGERDUTY_ROUTING_KEY=FROM_VAULT:migration/data/api-keys#pagerduty_prod_key
ALERT_EMAIL_RECIPIENTS=migration-oncall@company.com,platform-team@company.com
ALERT_EMAIL_SMTP_HOST=smtp.company.com
ALERT_EMAIL_SMTP_PORT=587

# ---- Storage ----
BLOB_STORAGE_PROVIDER=azure
AZURE_STORAGE_CONNECTION_STRING=FROM_VAULT:migration/data/azure#storage_connection_string
AZURE_STORAGE_CONTAINER=migration-artifacts-production
AWS_REGION=us-east-1
AWS_S3_BUCKET=migration-artifacts-prod-backup

# ---- Compliance ----
DLP_ENABLED=true
DLP_SCAN_OUTBOUND=true
DATA_RESIDENCY_REGION=us-east-1
GDPR_DATA_SUBJECT_RIGHTS_ENABLED=true
